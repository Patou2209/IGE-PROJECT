{
  "rules": {
    "utilisateurs": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "provinces": {
      ".read": true,
      ".write": "auth != null && auth.token.role === 'ige'"
    },
    "options_secondaire": {
      ".read": true,
      ".write": "auth != null && auth.token.role === 'ige'"
    },
    "cycles": {
      ".read": true,
      ".write": "auth != null && auth.token.role === 'ige'"
    },
    "sousDivisions": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChildren(['nom', 'ippId'])"
      }
    },
    "ecoles": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChildren(['nom', 'cycle', 'categorie', 'sdId', 'ippId'])"
      }
    },
    "classes": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChildren(['nom', 'cycle', 'niveau', 'professeurPrincipal', 'ecoleId'])"
      }
    },
    "effectifs": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$classeId": {
        ".validate": "newData.hasChildren(['nb_filles', 'nb_garcons', 'nb_filles_handicap', 'nb_garcons_handicap', 'lastUpdate'])",
        "nb_filles": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "nb_garcons": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "nb_filles_handicap": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "nb_garcons_handicap": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "lastUpdate": { ".validate": "newData.isNumber()" }
      }
    },
    "historique_effectifs": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$classeId": {
        "$timestamp": {
          ".validate": "newData.hasChildren(['nb_filles', 'nb_garcons', 'nb_filles_handicap', 'nb_garcons_handicap', 'utilisateur'])"
        }
      }
    }
  }
}